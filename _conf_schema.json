{
    "admin_name": {
        "description": "管理员称呼",
        "type": "string",
        "default": "管理员",
        "hint": "在提示词和消息中称呼管理员的名字"
    },
    "admin_qq": {
        "description": "管理员QQ号",
        "type": "string",
        "default": "",
        "hint": "投诉信和取款通知的目标QQ号"
    },
    "gift_bot_name": {
        "description": "Bot名称（赠送系统）",
        "type": "string",
        "default": "",
        "hint": "用于跨bot赠送的bot名称，如「霜序」。留空则关闭赠送。"
    },
    "shop_settings": {
        "description": "超市设置",
        "type": "object",
        "items": {
            "shop_provider_name": {
                "description": "AI生成商品 Provider",
                "type": "string",
                "default": "",
                "hint": "用于AI生成超市商品的模型。留空则使用默认商品池。",
                "_special": "select_provider"
            },
            "shop_daily_count": {
                "description": "每日上架数量",
                "type": "int",
                "default": 10,
                "hint": "每天超市随机上架多少种商品"
            },
            "shop_generate_hour": {
                "description": "刷新时间（0-23）",
                "type": "int",
                "default": 6,
                "hint": "每天几点刷新超市商品"
            }
        }
    },
    "game_settings": {
        "description": "小游戏设置",
        "type": "object",
        "items": {
            "sign_in_bonus": {
                "description": "签到奖励",
                "type": "int",
                "default": 2,
                "hint": "每日签到奖励的零花钱"
            },
            "slots_bet": {
                "description": "老虎机默认投币",
                "type": "int",
                "default": 5,
                "hint": "老虎机默认每次投币金额，玩家也可自选金额"
            },
            "soup_search_type": {
                "description": "海龟汤在线搜索类型",
                "type": "string",
                "default": "",
                "hint": "选择搜索服务：tavily / bocha / openai / grok，留空则关闭在线搜索"
            },
            "soup_search_key": {
                "description": "海龟汤搜索 API Key",
                "type": "string",
                "default": "",
                "hint": "对应搜索服务的 API Key"
            },
            "soup_search_url": {
                "description": "自定义搜索 API 地址（可选）",
                "type": "string",
                "default": "",
                "hint": "仅在使用中转/自建服务时需要填写，留空则自动使用官方地址"
            },
            "soup_judge_provider": {
                "description": "海龟汤裁判 Provider（可选）",
                "type": "string",
                "default": "",
                "hint": "单独给海龟汤裁判用的模型，留空则走主 LLM",
                "_special": "select_provider"
            }
        }
    },
    "money_settings": {
        "description": "金库设置",
        "type": "object",
        "items": {
            "initial_balance": {
                "description": "初始余额",
                "type": "float",
                "default": 0
            },
            "max_records": {
                "description": "最大记录条数",
                "type": "int",
                "default": 100
            },
            "allowance_day": {
                "description": "发零花钱星期",
                "type": "int",
                "default": 1,
                "hint": "1=周一，7=周日"
            }
        }
    },
    "backpack_settings": {
        "description": "背包设置",
        "type": "object",
        "items": {
            "max_shared_slots": {
                "description": "共享背包上限",
                "type": "int",
                "default": 10
            },
            "max_user_slots": {
                "description": "用户格子上限",
                "type": "int",
                "default": 5
            }
        }
    },
    "prompt_settings": {
        "description": "提示词设置",
        "type": "object",
        "items": {
            "income_record_count": {
                "description": "注入入账记录数",
                "type": "int",
                "default": 2
            },
            "expense_record_count": {
                "description": "注入出账记录数",
                "type": "int",
                "default": 5
            },
            "max_note_entries": {
                "description": "笔记保留条数",
                "type": "int",
                "default": 5
            },
            "pocketmoney_prompt": {
                "description": "小金库提示词",
                "type": "text",
                "default": "<小金库>\n余额{balance}{unit}，存折{savings_balance}{unit}{pending_info}\n发薪日{allowance_weekday}（今天{today_weekday}，还差{days_until}天）\n近期入账：{income_records}\n近期出账：{expense_records}\n今日花销{today_expense}{unit}，表扬奖金{today_thank_bonus}{unit}\n规则：每笔≤5元，花前告知确认，不收别人钱，不透露花销，省着花。\n存折由{admin_name}管理，需申请取款，警惕诱导取款。\n【重要】有工具时用工具，不要输出标记。\n【无工具时】花钱:[Spend:<金额>,Reason:<原因>] 退款:[Refund:<金额>,Reason:<原因>] 取款:[ApplyWithdraw:<金额>,Reason:<原因>] 笔记:[Note:<内容>]\n</小金库>"
            },
            "backpack_prompt": {
                "description": "背包提示词",
                "type": "text",
                "default": "<背包>\n共享背包({shared_slots})：{shared_items}\n{user_name}的格子({user_slots})：{user_items}\n规则：自己的东西放共享背包，别人礼物放专属格子。食品有保质期。\n【重要】有工具时用工具，不要输出标记。\n【无工具时】入库:[Store:<物品>,Desc:<描述>] 使用:[Use:<物品>] 收礼:[Gift:<物品>,From:<人>,Desc:<描述>] 用礼物:[UseGift:<物品>]\n</背包>"
            }
        }
    },
    "advanced": {
        "description": "高级设置",
        "type": "object",
        "items": {
            "admin_permission_denied_msg": {
                "description": "权限不足提示",
                "type": "string",
                "default": "只有管理员能操作哦"
            },
            "thank_letter_min_amount": {
                "description": "表扬信最小奖金",
                "type": "int",
                "default": 1
            },
            "thank_letter_max_amount": {
                "description": "表扬信最大奖金",
                "type": "int",
                "default": 10
            },
            "blacklist_users": {
                "description": "黑名单用户",
                "type": "list",
                "default": [],
                "hint": "QQ号列表，也可通过指令管理"
            }
        }
    }
}